{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/guard-protected-branch.sh\""
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "jq -r '.tool_input.file_path // empty' | { read -r f; case \"$f\" in *.ts) npx biome check --write \"$f\";; esac; } 2>/dev/null || true",
            "statusMessage": "Biome check..."
          },
          {
            "type": "command",
            "command": "jq -r '.tool_input.file_path // empty' | grep -q '\\.ts$' && npx tsc --noEmit || true",
            "statusMessage": "Type check..."
          }
        ]
      }
    ]
  }
}
